# Canlı Futures (mmbot3 varsayılanı). Testnet için: TESTNET=true
TESTNET=false
# Veri: tek combined WebSocket + REST recovery (ai-treding tarzı; main.py varsayılan)
# İzleme: API key olsa bile emir gönderme (paper simülasyon)
# PAPER_MODE=true
# PAPER_BALANCE_USD=75
# Otomatik pozisyon (trend analizi sonrası)
AUTO_TRADE=true
ENTRY_MODE=trend
IMPULSE_1M_TRADE=true
REQUIRE_HTF_ALIGN=true
JOURNAL_SAMPLE_SEC=10
# Trend skoru: son kac 15m mum (12=3 saat, 8=2 saat, 6=1.5 saat). ETH icin 8 deneyin.
# Giriş modu: break | range | hybrid | confirm | trend
# break = kırılım dışarı | range = S/R fade (TP band içi) | hybrid = ikisi
# ENTRY_MODE=hybrid
# V3 structure direction: son 3 swing high + son 3 swing low (toplam count=6)
# V3_STRUCTURE_SWING_COUNT=6
# V3 RANGE kalite esikleri (yon bazli; SELL genelde daha dusuk)
# V3_MIN_RANGE_SCORE=10
# V3_MIN_RANGE_SCORE_BUY=10
# V3_MIN_RANGE_SCORE_SELL=7
# Kanal teyidi swing bandi: destek/direnc fiyatinin ±%0.3 (0.003)
# V3_CHANNEL_BAND_PCT=0.003
# Kanal v2 (bps mesafe + 1m red + CVD eğimi; band %30/70 yok)
# RANGE_MIN_SCORE=65
# RANGE_PROXIMITY_BPS=35
# RANGE_SIDE_MARGIN_BPS=8
# RANGE_CHOP_DIFF_BPS=15
# RANGE_CENTER_MIN_BPS=28
# RANGE_CVD_SLOPE_SEC=90
# RANGE_CVD_SLOPE_MIN=60
# RANGE_1M_LOOKBACK=5
# RANGE_WICK_MIN=0.45
# RANGE_LEVEL_TOUCH_BPS=25
# ENTRY_MODE=break
# BREAK_HOLD_SEC=2
# BREAK_PROXIMITY_BPS=35
# ENTRY_COOLDOWN_SEC=300  (aynı swing seviyesi için, global değil)
# TP1_RETEST_MAX_REJECTS=2
# TP1_RETEST_EXIT_AFTER=3
# MARKET_DATA_MODE=aggtrade_ws_rest
# USER_STREAM_ENABLED=false
# LIQ_WS_ENABLED=false
# USER_STREAM_KEEPALIVE_SEC=1800
# WS_RECONNECT_DELAY_SEC=5
# REST_PRICE_POLL_SEC=5
# REST_KLINE_1M_POLL_SEC=5
# REST_KLINE_15M_POLL_SEC=20
# REST_KLINE_1H_POLL_SEC=60
# TRADE_STALE_SECONDS=45
# TRADE_WS_ENABLED=false
# MARKET_RECOVERY_POLL_SEC=5
# MARKET_RECOVERY_REST_DELAY_SEC=30
# OI_ENTRY_LOOKBACK_SEC=30
# BREAK_MIN_RR_UNCLEAR=2.0
# Grafik hizası (üst panel bilgi)
# PULSE_BARS_1M=15
# TIMING_BARS_15M=4
BALANCE_API_TIMEOUT_SEC=18
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Dashboard: Claude aciklama (opsiyonel; dashboard'dan da girilebilir)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
